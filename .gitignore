# =============================================================
# Verit — .gitignore
# =============================================================F

# -------------------------------------------------------------
# SECRETS & ENVIRONMENT VARIABLES
# Never push API tokens or credentials to GitHub
# -------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
secrets.json

# -------------------------------------------------------------
# PYTHON VIRTUAL ENVIRONMENT
# Recreated by anyone cloning the repo via pip install -r requirements.txt
# -------------------------------------------------------------
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/

# -------------------------------------------------------------
# PYTHON CACHE & COMPILED FILES
# Auto-generated, never need to be version controlled
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# -------------------------------------------------------------
# RAW DATA FILES
# Too large for GitHub — CourtListener JSON dumps can be GBs
# Recreated by running data/fetch_cases.py
# -------------------------------------------------------------
data/raw/
data/processed/
*.json
*.csv
*.parquet

# Exception: keep any small sample/fixture files used in tests
!data/fixtures/*.json
!data/samples/*.json

# -------------------------------------------------------------
# MILVUS LOCAL DATABASE FILES
# Recreated by running the embedding pipeline
# -------------------------------------------------------------
*.db
milvus_data/
milvus.db
milvus_lite/

# -------------------------------------------------------------
# NEO4J LOCAL DATA VOLUMES
# Managed by Docker — not source code
# -------------------------------------------------------------
neo4j_data/
neo4j_logs/
neo4j_import/
neo4j_plugins/

# -------------------------------------------------------------
# BENCHMARK & EVALUATION OUTPUTS
# Large result files and generated datasets
# Keep scripts, not outputs
# -------------------------------------------------------------
benchmark/results/*.csv
benchmark/results/*.json
benchmark/generated/

# Exception: keep the final evaluation summary
!benchmark/results/final_eval_summary.json

# -------------------------------------------------------------
# MODEL WEIGHTS & EMBEDDINGS
# Too large for GitHub — download from HuggingFace at runtime
# -------------------------------------------------------------
models/
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
embeddings/vectors/
embeddings/index/

# -------------------------------------------------------------
# JUPYTER NOTEBOOKS CHECKPOINTS
# Auto-generated by Jupyter, not needed in version control
# -------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -------------------------------------------------------------
# OS & EDITOR FILES
# Machine-specific files that have no place in the repo
# -------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store
.AppleDouble
.LSOverride
._*

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm etc.)
.idea/
*.iml

# -------------------------------------------------------------
# LOGS & TEMPORARY FILES
# -------------------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.swp
*.swo
tmp/
temp/

# -------------------------------------------------------------
# DOCKER OVERRIDE FILES
# Local docker overrides should not be shared
# -------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml
